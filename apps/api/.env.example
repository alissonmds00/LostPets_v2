NODE_ENV=development
PORT=3001

# Host port is 5433 (not the default 5432) to avoid clashing with a locally
# installed Postgres service, if you have one running.
DATABASE_URL=postgresql://postgres:postgres@localhost:5433/lost_pets?schema=public

SESSION_COOKIE_NAME=lost_pets_sid
# Generate with: openssl rand -base64 32
SESSION_COOKIE_SECRET=
# How long a login session stays valid, in days.
SESSION_TTL_DAYS=7

CORS_ORIGIN=http://localhost:3000

STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
# Only needed when STORAGE_DRIVER=s3
S3_BUCKET=
S3_REGION=

# Pet registration is enqueued to SQS (avoids losing a registration if the DB
# is overloaded); LocalStack simulates it locally, real SQS is used in prod.
# `docker compose up` creates the queue automatically (see
# infra/localstack/init/) — no manual setup needed. These values are for
# running apps/api on the host (npm run dev); the api container itself gets
# SQS_ENDPOINT overridden to the localstack service name (see docker-compose.yml).
SQS_QUEUE_URL=http://localhost:4566/000000000000/pets-registration
SQS_REGION=us-east-1
SQS_ENDPOINT=http://localhost:4566
