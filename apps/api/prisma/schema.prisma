generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// identity module (phase 1 — see PLAN.md)
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  role         Role      @default(USER)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  sessions    Session[]
  petListings PetListing[]
  reports     Report[]

  // Duas relações nomeadas pro mesmo model (Message) — Prisma exige um nome
  // explícito quando há mais de uma FK entre os mesmos dois models, senão não
  // sabe qual `Message.senderId`/`receiverId` corresponde a qual lado.
  sentMessages     Message[] @relation("MessageSender")
  receivedMessages Message[] @relation("MessageReceiver")

  @@map("users")
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@map("sessions")
}

// ---------------------------------------------------------------------------
// pets module (phase 2 — see PLAN.md)
// ---------------------------------------------------------------------------

enum PetListingType {
  LOST
  FOUND
  DONATION
}

enum PetListingStatus {
  ACTIVE
  RESOLVED
  CANCELLED
}

model PetListing {
  id          String           @id @default(uuid())
  type        PetListingType
  title       String
  description String
  species     String
  latitude    Float
  longitude   Float
  city        String
  status      PetListingStatus @default(ACTIVE)
  ownerId     String
  owner       User             @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?

  photos   PetPhoto[]
  messages Message[]
  reports  Report[]

  @@index([ownerId])
  @@map("pet_listings")
}

model PetPhoto {
  id         String     @id @default(uuid())
  listingId  String
  listing    PetListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  storageKey String
  url        String
  order      Int
  createdAt  DateTime   @default(now())

  @@index([listingId])
  @@map("pet_photos")
}

// ---------------------------------------------------------------------------
// messaging module (phase 3 — see PLAN.md)
// ---------------------------------------------------------------------------

model Message {
  id         String     @id @default(uuid())
  senderId   String
  sender     User       @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId String
  receiver   User       @relation("MessageReceiver", fields: [receiverId], references: [id], onDelete: Cascade)
  listingId  String
  listing    PetListing @relation(fields: [listingId], references: [id], onDelete: Cascade)
  body       String
  createdAt  DateTime   @default(now())
  // Delivery receipt (não "lida pelo usuário") — setado quando a mensagem é
  // entregue com sucesso ao socket aberto do destinatário no momento do
  // envio; null enquanto o destinatário está offline. Decidido com o usuário
  // em 2026-07-09 — ver skill messaging.
  readAt     DateTime?

  @@index([listingId])
  @@index([senderId])
  @@index([receiverId])
  @@map("messages")
}

// ---------------------------------------------------------------------------
// moderation module (phase 4 — see PLAN.md)
// ---------------------------------------------------------------------------

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

model Report {
  id         String       @id @default(uuid())
  reporterId String
  reporter   User         @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  listingId  String
  listing    PetListing   @relation(fields: [listingId], references: [id], onDelete: Cascade)
  reason     String
  status     ReportStatus @default(PENDING)
  createdAt  DateTime     @default(now())

  @@index([reporterId])
  @@index([listingId])
  @@map("reports")
}
